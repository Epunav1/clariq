# CLARIQ Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ==== Application ====
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# ==== Server ====
BACKEND_URL=https://api.tryclariq.com
FRONTEND_URL=https://tryclariq.com
CORS_ORIGINS=https://tryclariq.com,https://www.tryclariq.com

# ==== Database - SQLite (local) ====
DATABASE_URL=sqlite:///./data/clariq.db
DB_BACKUP_PATH=./data/backups

# ==== Database - PostgreSQL (production optional) ====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clariq
POSTGRES_USER=clariq
POSTGRES_PASSWORD=change-me-in-production

# ==== Snowflake Data Warehouse ====
SNOWFLAKE_ACCOUNT=your-account.us-east-1
SNOWFLAKE_USER=clariq_user
SNOWFLAKE_PASSWORD=change-me-in-production
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CLARIQ_DB
SNOWFLAKE_SCHEMA=SHOPIFY_RAW

# ==== Email / SMTP ====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@clariq.com
SMTP_TLS=true

# ==== JWT / Security ====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
API_KEY_SECRET=your-api-key-secret

# ==== Shopify Integration ====
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_PASSWORD=your-shopify-password
SHOPIFY_SCOPE=read_orders,read_customers,read_products
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ==== Amazon Integration ====
AMAZON_ACCESS_KEY_ID=your-amazon-access-key
AMAZON_SECRET_ACCESS_KEY=your-amazon-secret-key
AMAZON_SELLER_ID=your-seller-id
AMAZON_REGION=us-east-1

# ==== Slack Integration ====
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==== Google Sheets Integration ====
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# ==== Stripe Billing ====
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ==== Performance & Monitoring ====
ENABLE_METRICS=true
METRICS_PORT=8001
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ==== Feature Flags ====
ENABLE_ANALYTICS=true
ENABLE_EXPORTS=true
ENABLE_ALERTS=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_BILLING=true

# ==== Scheduler ====
RUN_INITIAL_SYNC=true
SYNC_INTERVAL_HOURS=6
MILESTONE_CHECK_INTERVAL_MINUTES=30
REPORT_SEND_DAY=1
REPORT_SEND_HOUR=9

# ==== File Storage ====
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=csv,xlsx,xls,json

# ==== Development (only if needed) ====
# MOCK_SNOWFLAKE=false
# SKIP_EMAIL=false
